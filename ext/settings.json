        "SambaInterruptionChecker": {
            "enable": true,
            "stay_awake": 5
        },
        "CupsInterruptionChecker": {
            "enable": true,
            "stay_awake": 3
        },
        "CronInterruptionChecker": {
            "enable": true,
            "stay_awake": 10,
            "extra_wakeup_time": 1,
            "users": [
                "heckie",
                "root"
            ],
            "tabfiles": [],
            "ignore_frequency": {
                "max_per_year": 366
            }
        },
        "LoadInterruptionChecker": {
            "enable": true,
