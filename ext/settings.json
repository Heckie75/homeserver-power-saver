{
    "dryrun": false,
    "mode": "mem",
    "dbus": true,
    "respite_prepare": 10,
    "respite_recover": 10,
    "min_uptime": 10,
    "min_downtime": 10,
    "checkers": {
        "PowerSaverInterruptionChecker": {
            "enable": true,
            "uptimes": [
                {
                    "days": [],
                    "from": "6:45",
                    "until": "7:35"
                }
            ],
            "preaction": true,
            "preactions": [
                [
                    "sudo",
                    "-u",
                    "heckie",
                    "VBoxManage",
                    "controlvm",
                    "Windows 10 pro",
                    "pause"
                ]
            ],
            "postaction": true,
            "postactions": [
                [
                    "/home/heckie/bin/rc.local"
                ],
                [
                    "sudo",
                    "-u",
                    "heckie",
                    "VBoxManage",
                    "controlvm",
                    "Windows 10 pro",
                    "resume"
                ],
                [
                    "systemctl",
                    "restart",
                    "saned.socket"
                ]
            ]
        },
        "XIdleInterruptionChecker": {
            "enable": true,
            "stay_awake": 5,
            "ignore_periods": [
                {
                    "days": [
                        0,
                        1,
                        2,
                        3,
                        6
                    ],
                    "from": "23:30",
                    "until": "6:00"
                }
            ],
            "min_idle": 10,
            "users": [
                "heckie"
            ]
        },
        "WhoInterruptionChecker": {
            "enable": true,
            "stay_awake": 5,
            "ignore_periods": [
                {
                    "days": [
                        0,
                        1,
                        2,
                        3,
                        6
                    ],
                    "from": "23:30",
                    "until": "6:00"
                }
            ],
            "ignore_lines": [
                "tty7"
            ]
        },
        "ProcessInterruptionChecker": {
            "enable": true,
            "stay_awake": 2,
            "processes": [
                "tar",
                "dd",
                "gzip",
                "zip",
                "unzip",
                "7z",
                "cp",
                "scp",
                "rsync",
                "apt",
                "clamscan",
                "brasero",
                "genisoimage",
                "wodim",
                "rec",
                "wget",
                "curl",
                "node",
                "VBoxManage"
            ]
        },
        "KodiInterruptionChecker": {
            "enable": true,
            "stay_awake": 5,
            "ignore_periods": [
                {
                    "days": [
                        0,
                        1,
                        2,
                        3,
                        6
                    ],
                    "from": "23:30",
                    "until": "4:30"
                }
            ],
            "preaction": true,
            "host": "192.168.178.20",
            "port": 9080,
            "user": "kodi",
            "password": "kodi"
        },
        "KodiTimersInterruptionChecker": {
            "enable": true,
            "extra_wakeup_time": 1,
            "ignore_periods": [],
            "path": "/home/heckie/.kodi",
            "postaction": true,
            "host": "192.168.178.20",
            "port": 9080,
            "user": "kodi",
            "password": "kodi"
        },
        "KodiWizInterruptionChecker": {
            "enable": true,
            "stay_awake": 5,
            "ignore_periods": [],
            "path": "/home/heckie/.kodi/userdata/addon_data/script.wiz/running_programs.json",
            "preaction": true,
            "postaction": true,
            "host": "192.168.178.20",
            "port": 9080,
            "user": "kodi",
            "password": "kodi"
        },
        "TvHeadendInterruptionChecker": {
            "enable": true,
            "stay_awake": 5,
            "extra_wakeup_time": 7,
            "host": "192.168.178.20",
            "port": 9981,
            "user": "tvheadenduser",
            "password": "tvheadenduser"
        },
        "TvHeadendEpgGrabberInterruptionChecker": {
            "enable": true,
            "epg_config_path": "/var/lib/tvheadend/epggrab/config",
